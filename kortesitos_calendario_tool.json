      ]
    },
    "Consultar Calendario": {
      "main": [
        [{ "node": "Evaluar Disponibilidad", "type": "main", "index": 0 }]
      ]
    },
    "Crear Evento Calendario": {
      "main": [
        [{ "node": "Confirmar Creacion", "type": "main", "index": 0 }]
      ]
    }
  },
